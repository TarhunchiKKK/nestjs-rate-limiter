    },
    "homepage": "https://github.com/TarhunchiKKK/nestjs-rate-limiter.git#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/TarhunchiKKK/nestjs-rate-limiter.git"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
