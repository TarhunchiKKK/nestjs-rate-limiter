        "test:e2e": "bun test tests/e2e --preload ./tests/preload.ts"
    },
    "devDependencies": {
        "@nestjs/common": "^11.1.27",
        "@nestjs/core": "^11.1.27",
        "@nestjs/testing": "^11.1.27",
        "@types/bun": "latest",
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.1",
        "bun-plugin-swc": "^0.0.1",
        "express": "^5.2.1",
        "ioredis": "^5.11.1",
        "reflect-metadata": "^0.2.2"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/core": "^11.0.0",
        "ioredis": "^5.0.0",
        "typescript": "^5"
    }
