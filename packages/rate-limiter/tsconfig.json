{
    "compilerOptions": {
        "module": "commonjs",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "noImplicitAny": false,
        "noUnusedLocals": true,
        "removeComments": true,
        "skipLibCheck": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "strictNullChecks": true,
        "target": "es6",
        "sourceMap": true,
        "outDir": "./dist/src",
        "types": ["bun"]
    },
    "include": ["src", "tests"]
}
