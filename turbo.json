{
    "$schema": "https://turborepo.dev/schema.json",
    "globalDependencies": ["**/.env.*local"],
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
        },
        "lint": {},
        "type-check": {},
        "test:unit": {},
        "test:types": {},
        "test:e2e": {}
    }
}
